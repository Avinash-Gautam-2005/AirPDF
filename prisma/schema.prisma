// AirPDF Database Schema
// Using Prisma with Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================
// ENUMS
// ===================

enum Role {
  CUSTOMER
  SHOPKEEPER
  ADMIN
}

enum OrderStatus {
  PENDING
  PRINTING
  COMPLETED
  CANCELLED
}

enum ColorMode {
  BW
  COLOR
}

// ===================
// USER & AUTH TABLES
// ===================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          Role      @default(CUSTOMER)
  image         String?
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts Account[]
  sessions Session[]
  shop     Shop?    @relation("ShopOwner")
  orders   Order[]   @relation("CustomerOrders")

  @@map("users")
}

// NextAuth.js required tables
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===================
// BUSINESS TABLES
// ===================

model Shop {
  // Make `Shop.id` the same value as the owning `User.id` (one-to-one)
  // This enforces that a user can have at most one shop and that
  // the shop's primary key equals the owner's user id.
  id        String   @id @map("owner_id")
  name      String
  qrCodeUrl String?  @map("qr_code_url")
  address   String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations (one-to-one: Shop.id <-> User.id)
  owner  User    @relation("ShopOwner", fields: [id], references: [id], onDelete: Cascade)
  orders Order[]
  @@map("shops")
}

model Order {
  id String @id @default(uuid())

  // Shop relation
  shopId String @map("shop_id")
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Customer relation
  customerId String @map("customer_id")
  customer   User   @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  
  // Cloudinary file info
  filePublicId  String  @map("file_public_id")
  fileUrl       String  @map("file_url")
  fileName      String? @map("file_name")
  fileSizeBytes Int?    @map("file_size_bytes")
  pageCount     Int?    @map("page_count")

  // Print options
  copies      Int       @default(1)
  colorMode   ColorMode @default(BW) @map("color_mode")
  pageRange   String?   @map("page_range") // e.g., "1-5,8,10-12" or null for all
  doubleSided Boolean   @default(false) @map("double_sided")

  // Pricing (future)
  pricePerPage Decimal? @map("price_per_page") @db.Decimal(10, 2)
  totalPrice   Decimal? @map("total_price") @db.Decimal(10, 2)

  // Status tracking
  status          OrderStatus @default(PENDING)
  statusUpdatedAt DateTime    @default(now()) @map("status_updated_at")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  @@index([shopId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}
